<Window x:Class="FELauncher.UI.Desktop.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FELauncher.UI.Desktop.Views"
        xmlns:viewmodels="clr-namespace:FELauncher.UI.Desktop.ViewModels"
        xmlns:sections="clr-namespace:FELauncher.UI.Desktop.Views.Sections"
        d:DataContext="{d:DesignInstance Type=viewmodels:SettingsWindowViewModel}"
        mc:Ignorable="d"
        Title="FE Launcher Settings"
        Width="650" SizeToContent="Height"
        Closing="SettingsWindow_Closing"
        MouseDown="SettingsWindow_MouseDown"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        ThemeMode="Light">

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:GeneralSectionViewModel}"><sections:GeneralSection /></DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:FrontendSectionViewModel}"><sections:FrontendSection /></DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:PreProcessesSectionViewModel}"><sections:PreProcessesSection /></DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListView Grid.Column="0"
                      Margin="10,10,10,0"
                      ItemsSource="{Binding NavItems}"
                      SelectedItem="{Binding SelectedNavItem}"
                      SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Title}"
                                   VerticalAlignment="Center"
                                   Margin="8,6" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <ContentControl Grid.Column="1" Content="{Binding SelectedNavItem.Content}" />
        </Grid>

        <Grid Grid.Row="1"
              Margin="0,10,0,0"
              Background="{DynamicResource ControlAltFillColorSecondaryBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding AppVersion}"
                       VerticalAlignment="Bottom"
                       Margin="10"
                       Opacity=".40" />

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="10">
                <Button Content="OK"
                        Command="{Binding OkCommand}"
                        Width="70" />
                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Width="70"
                        Margin="10,0,0,0" />
            </StackPanel>
        </Grid>
    </Grid>

</Window>
