<Window x:Class="FELauncher.UI.Desktop.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FELauncher.UI.Desktop.Views"
        xmlns:viewmodels="clr-namespace:FELauncher.UI.Desktop.ViewModels"
        d:DataContext="{d:DesignInstance Type=viewmodels:SettingsWindowViewModel}"
        mc:Ignorable="d"
        Title="Settings"
        Width="420" SizeToContent="Height"
        Closing="SettingsWindow_Closing"
        MouseDown="SettingsWindow_MouseDown"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Background="#f0f0f0">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="72" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Image Grid.Row="0"
               Source="/FELauncher.UI.Desktop;component/logo.png"
               Width="230" Height="60"
               Stretch="None"
               HorizontalAlignment="Center" VerticalAlignment="Center" 
               RenderOptions.BitmapScalingMode="NearestNeighbor"
               SnapsToDevicePixels="True" UseLayoutRounding="True" />

        <TabControl Grid.Row="1" Margin="10,0,10,0">
            <TabItem Header="General">
                <Border Padding="15">
                    <StackPanel>
                        <CheckBox IsChecked="{Binding StartWithWindows}"
                                  Height="22" VerticalContentAlignment="Center">
                            Start with Windows
                        </CheckBox>
                        <CheckBox IsChecked="{Binding AutoLaunchSession}"
                                  Height="22" VerticalContentAlignment="Center">
                            Automatically launch session on app startup
                        </CheckBox>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding DisableNotifications}"
                                      Height="22" VerticalContentAlignment="Center">
                                Disable notifications
                            </CheckBox>
                            <Image Source="/FELauncher.UI.Desktop;component/information_tip.png"
                                   Width="32" Height="Auto"
                                   Stretch="None"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   SnapsToDevicePixels="True" UseLayoutRounding="True"
                                   ToolTip="Supress all system notifications. Overrides other notification options."
                                   ToolTipService.InitialShowDelay="400" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Label Padding="0,0,5,0"
                                   VerticalAlignment="Center">
                                End session grace period:
                            </Label>
                            <TextBox Text="{Binding EndSessionGracePeriod}"
                                     Width="25" Height="20"
                                     VerticalAlignment="Center" VerticalContentAlignment="Center" />
                            <Image Source="/FELauncher.UI.Desktop;component/information_tip.png"
                                   Width="32" Height="Auto"
                                   Stretch="None"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   SnapsToDevicePixels="True" UseLayoutRounding="True"
                                   ToolTip="Time, in seconds, to wait after sending a close signal to session windows."
                                   ToolTipService.InitialShowDelay="400" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="Frontend">
                <Border Padding="15">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0"
                                   Padding="0,0,5,0"
                                   VerticalAlignment="Center">
                                Path:
                            </Label>
                            <TextBox Text="{Binding FrontendPath}"
                                     Grid.Column="1"
                                     Height="20" VerticalContentAlignment="Center" />
                            <Image Grid.Column="2"
                                   Source="/FELauncher.UI.Desktop;component/file_selector.png"
                                   Width="32" Height="20"
                                   Stretch="None"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   SnapsToDevicePixels="True" UseLayoutRounding="True"
                                   ToolTip="Open file selector"
                                   ToolTipService.InitialShowDelay="400" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Label Padding="0,0,5,0"
                                       VerticalAlignment="Center">
                                    Delay:
                                </Label>
                                <TextBox Text="{Binding FrontendDelaySeconds}"
                                         Width="25" Height="20"
                                         VerticalAlignment="Center" VerticalContentAlignment="Center" />
                                <Image Source="/FELauncher.UI.Desktop;component/information_tip.png"
                                       Width="32" Height="Auto"
                                       Stretch="None"
                                       VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                       SnapsToDevicePixels="True" UseLayoutRounding="True"
                                       ToolTip="Time, in seconds, to wait before launching the frontend."
                                       ToolTipService.InitialShowDelay="400" />
                            </StackPanel>

                            <CheckBox IsChecked="{Binding FrontendNotifyOnExit}"
                                      Height="20" Margin="20,0,0,0"
                                      VerticalContentAlignment="Top">
                                Notify on exit
                            </CheckBox>

                            <CheckBox IsChecked="{Binding FrontendEndSessionOnExit}"
                                      Height="20" Margin="10,0,0,0"
                                      VerticalContentAlignment="Top">
                                End session on exit
                            </CheckBox>
                        </StackPanel>

                        <Grid Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0"
                                   Padding="0,0,5,0"
                                   VerticalAlignment="Center">
                                Args:
                            </Label>
                            <TextBox Text="{Binding FrontendArgs}"
                                     Grid.Column="1"
                                     Height="20" VerticalContentAlignment="Center" />
                            <Image Grid.Column="2"
                                   Source="/FELauncher.UI.Desktop;component/clear_text.png"
                                   Width="20" Height="14"
                                   Stretch="None"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   SnapsToDevicePixels="True" UseLayoutRounding="True"
                                   ToolTip="Clear args"
                                   ToolTipService.InitialShowDelay="400" />
                        </Grid>
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="Pre-processes">
            </TabItem>

            <TabItem Header="Shortcuts">
            </TabItem>

            <TabItem Header="Advanced">
            </TabItem>
        </TabControl>

        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding AppVersion}"
                       VerticalAlignment="Bottom"
                       Opacity=".40" />

            <StackPanel Grid.Column="1"
                        Height="24"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <Button Content="OK"
                        Command="{Binding OkCommand}"
                        Margin="0,0,10,0"
                        Width="72" />
                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Width="72" />
            </StackPanel>
        </Grid>
    </Grid>

</Window>
