<Window x:Class="FELauncher.UI.Desktop.Views.PreProcessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FELauncher.UI.Desktop.Views"
        mc:Ignorable="d"
        Title="Edit Pre-process"
        Width="540" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        ThemeMode="Light">

    <Border Margin="15">
        <local:ProcessSettingsUserControl DataContext="{Binding ProcessSettingsViewModel}" />
    </Border>

</Window>
