<UserControl x:Class="FELauncher.UI.Desktop.Views.GeneralSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FELauncher.UI.Desktop.Views"
             mc:Ignorable="d">

    <Border Margin="15">
        <StackPanel>
            <CheckBox Content="Start with Windows"
                      IsChecked="{Binding StartWithWindows}" />

            <CheckBox Content="Automatically launch session on app startup"
                      IsChecked="{Binding AutoLaunchSession}" />

            <CheckBox Content="Disable notifications"
                      IsChecked="{Binding DisableNotifications}"
                      ToolTip="Supress all system notifications. Overrides other notification options."
                      ToolTipService.InitialShowDelay="400" />

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Label Content="End session grace period:"
                       Padding="0,0,5,0"
                       VerticalAlignment="Center"
                       ToolTip="Time, in seconds, to wait after sending a close signal to session windows."
                       ToolTipService.InitialShowDelay="400" />
                <TextBox Text="{Binding EndSessionGracePeriod}"
                         Width="68"
                         VerticalAlignment="Center" VerticalContentAlignment="Center" />
            </StackPanel>
        </StackPanel>
    </Border>

</UserControl>
