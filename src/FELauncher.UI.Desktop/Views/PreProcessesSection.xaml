<UserControl x:Class="FELauncher.UI.Desktop.Views.PreProcessesSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FELauncher.UI.Desktop.Views"
             xmlns:converters="clr-namespace:FELauncher.UI.Desktop.Views.Converters"
             mc:Ignorable="d"
             xmlns:md="https://github.com/fantasticfiasco/mvvm-dialogs"
             md:DialogServiceViews.IsRegistered="True">

    <UserControl.Resources>
        <converters:ProcessPathConverter x:Key="ProcessPathConverter" />
    </UserControl.Resources>

    <Border Margin="15">
        <StackPanel Orientation="Vertical">
            <Border BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button Content="Add" Command="{Binding AddCommand}" />
                        <Button Content="Edit" Command="{Binding EditCommand}"
                                Margin="10,0,0,0" />
                        <Button Content="Delete" Command="{Binding DeleteCommand}"
                                Margin="10,0,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Move up" Command="{Binding MoveUpCommand}" />
                        <Button Content="Move down" Command="{Binding MoveDownCommand}"
                                Margin="10,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <ListView ItemsSource="{Binding PreProcesses}"
                      SelectedItem="{Binding SelectedPreProcess}"
                      SelectionMode="Single"
                      MaxHeight="250"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      VirtualizingPanel.ScrollUnit="Pixel"
                      Margin="0,10,0,0">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Path, Converter={StaticResource ProcessPathConverter}}">
                            <TextBlock.InputBindings>
                                <MouseBinding Gesture="LeftDoubleClick"
                                              Command="{Binding Path=DataContext.EditCommand,
                                              RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
                            </TextBlock.InputBindings>
                        </TextBlock>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Border>

</UserControl>
