<UserControl x:Class="FELauncher.UI.Desktop.Views.ProcessSettingsUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FELauncher.UI.Desktop.Views"
             mc:Ignorable="d"
             xmlns:md="https://github.com/fantasticfiasco/mvvm-dialogs"
             md:DialogServiceViews.IsRegistered="True">

    <StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0"
                   Content="Path:"
                   Padding="0,0,5,0"
                   VerticalAlignment="Center" />
            <TextBox Text="{Binding Path}"
                     Grid.Column="1"
                     VerticalContentAlignment="Center" />
            <Button Grid.Column="2"
                    Content="Choose file"
                    Command="{Binding ShowOpenFileDialogCommand}"
                    Margin="6,0,0,0" />
        </Grid>

        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">

            <CheckBox Content="Notify on exit"
                      IsChecked="{Binding NotifyOnExit}"
                      VerticalContentAlignment="Top" />

            <CheckBox Content="End session on exit"
                      IsChecked="{Binding EndSessionOnExit}"
                      Margin="10,0,0,0"
                      VerticalContentAlignment="Top" />
        </StackPanel>

        <Grid Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0"
                   Content="Delay:"
                   Padding="0,0,5,0"
                   VerticalAlignment="Center"
                   ToolTip="Time, in seconds, to wait before launching the process."
                   ToolTipService.InitialShowDelay="400" />
            <TextBox Grid.Column="1"
                     Text="{Binding DelaySeconds}"
                     Width="68"
                     VerticalAlignment="Center" VerticalContentAlignment="Center" />

            <Label Grid.Column="2"
                   Content="Args:"
                   Margin="10,0,0,0"
                   Padding="0,0,5,0"
                   VerticalAlignment="Center" />
            <TextBox Grid.Column="3"
                     Text="{Binding Arguments}"
                     VerticalContentAlignment="Center" />
        </Grid>
    </StackPanel>

</UserControl>
